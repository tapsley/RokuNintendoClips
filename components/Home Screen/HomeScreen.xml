<?xml version="1.0" encoding="utf-8" ?> 

<component name="HomeScreen" extends="Group"  initialFocus="gameGrid">
    <script type="text/brightscript" uri="HomeScreen.brs" />
	 <interface>
        <field id="content" type="node" alias="gameGrid.content" />
        <field id="selectedGame" type="string" />
        <field id="searchRequested" type="string" />
        <field id="randomRequested" type="string" />
    </interface>
    <children>

        <Poster
            id="searchButton"
            translation="[35,300]"
            width="90"
            height="90"
            uri="pkg:/images/search_icon.png" />

        <Poster
            id="randomButton"
            translation="[35,390]"
            width="90"
            height="90"
            uri="pkg:/images/random_icon.png" />

        <PosterGrid
            id="gameGrid"
            translation="[195,155]"
            basePosterSize="[200,200]"
            itemSpacing="[30,28]"
            caption1NumLines="1"
            caption1Font="font:SmallSystemFont"
            caption1Color="0x0D61D3"
            numColumns="4"
            animateToItem="1"
            enableCaptionScroller="true"
            captionBackgroundBitmapUri="pkg:/images/caption_bg.png"
            numRows="3"/>


    </children>
</component>